<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - POEM Pricing</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
<style type="text/css">
        table thead th {
            text-align: center;
        }
        .form-label {
            white-space: nowrap;
        }
        .sidebar {
            min-width: 200px;
            max-width: 250px;
            min-height: 100vh;
            background: #f8f9fa;
            border-right: 1px solid #dee2e6;
            transition: all 0.3s;
        }
    .sidebar .nav-link {
      color: #333;
    }
    .hamburger {
      font-size: 2rem;
      cursor: pointer;
    }
    @@media (max-width: 991.98px) {
      .sidebar {
        position: fixed;
        height: 100%;
        z-index: 1040;
      }
    }

    #loader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(255,255,255,0.7);
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
}

.spinner {
    width: 50px;
    height: 50px;
    border: 5px solid #ddd;
    border-top: 5px solid #3498db;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}

@@keyframes spin {
    100% {
        transform: rotate(360deg);
    } }
</style>
</head>
<body>
    <div class="container-fluid px-0">
        <div class="d-flex">
            <!-- Sidebar (hidden by default) -->
            <div class="collapse sidebar" id="sidebarMenu">
                <nav class="nav flex-column py-3">
                    @Html.ActionLink("Home", "Index", "SKU", new { area = "" }, new { @class = "nav-link" })
                    @Html.ActionLink("New", "Create", "SKU", new { area = "" }, new { @class = "nav-link" })
                    <a class="nav-link" href="#">BOM</a>
                    <a class="nav-link" href="#">Proposals</a>
                    <a class="nav-link" href="#">Reports</a>
                    <a class="nav-link" id="btnLogout" href="#">Logout</a>
                </nav>
            </div>
            <!-- Main Content -->
            <div class="flex-grow-1">
                <!-- Hamburger Button -->
                <nav class="navbar bg-light" style="padding: 0px;">
                    <button class="btn hamburger me-3" style="padding: 0px;" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarMenu">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <span class="navbar-brand mb-0 h1">@Html.ActionLink("POEM Pricing", "Index", "Home", new { area = "" }, new { @class = "navbar-brand" })</span>
                </nav>
                <div class="body-content py-2 " style="margin-top: 0px;">
                    @RenderBody()
                    @*<hr />
                        <footer>
                            <p>&copy; @DateTime.Now.Year - My ASP.NET Application</p>
                        </footer>*@
                </div>
            </div>
        </div>
    </div>
    <div id="loader" style="display:none;">
        <div class="spinner"></div>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    <!-- jQuery (only one version) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- jQuery UI (after jQuery) -->
    <link rel="stylesheet"
          href="https://code.jquery.com/ui/1.13.3/themes/base/jquery-ui.css" />
    <script src="https://code.jquery.com/ui/1.13.3/jquery-ui.min.js"></script>
    <script src="~/Scripts/html2canvas.js"></script>
    <script src="~/Scripts/jspdf.js"></script>
    @RenderSection("scripts", required: false)
    <script>
    var webRoot = "@System.Configuration.ConfigurationManager.AppSettings["WebRoot"]";


    $("#btnLogout").on("click", function () {
        $.ajax({
            url: "/api/login/logout",
            type: "POST",
            success: function (response) {
                // Redirect to login page
                window.location.href = webRoot + "Home/Index";
            },
            error: function () {

            }
        });
    });


        // Global AJAX loader for all jQuery AJAX / JSON calls

        $(document).ready(function () {

            // Show loader when AJAX starts
            $(document).ajaxStart(function () {
                $("#loader").show();
            });

            // Hide loader when AJAX stops
            $(document).ajaxStop(function () {
                $("#loader").hide();
            });

        });
    </script>
</body>
</html>
